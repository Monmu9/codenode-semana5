---
import Layout from "../../layouts/Layout.astro";

export function getStaticPaths() {
  return [
    { params: { slug: "gastroreservas" } },
    { params: { slug: "monbank" } },
    { params: { slug: "codigo-de-vida" } },
  ];
}

const { slug } = Astro.params;

const proyectos = {
  "gastroreservas": {
    titulo: "GastroReservas",
    descripcion: "Sistema de reservas para restaurantes con PHP, MySQL y REST API.",
    tecnologias: ["PHP", "MySQL", "REST API"]
  },
  "monbank": {
    titulo: "MONBANK",
    descripcion: "App bancaria simulada con Chart.js y datos en JSON.",
    tecnologias: ["JavaScript", "Chart.js", "JSON"]
  },
  "codigo-de-vida": {
    titulo: "Código de Vida",
    descripcion: "App web de emergencias con acceso a perfiles médicos por QR y NFC.",
    tecnologias: ["Astro", "QR", "NFC"]
  }
};

const proyecto = proyectos[slug];
---

<Layout title={proyecto.titulo}>
  <a href="/codenode-semana5/proyectos" class="text-teal-400 text-sm hover:underline mb-8 inline-block">← Volver a proyectos</a>
  <h1 class="text-4xl font-bold text-white mb-4">{proyecto.titulo}</h1>
  <p class="text-gray-400 mb-6">{proyecto.descripcion}</p>
  <div class="flex gap-2 flex-wrap">
    {proyecto.tecnologias.map((tec) => (
      <span class="bg-teal-900 text-teal-300 text-xs px-3 py-1 rounded-full">{tec}</span>
    ))}
  </div>
</Layout>